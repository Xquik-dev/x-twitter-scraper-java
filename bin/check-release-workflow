#!/usr/bin/env bash

set -euo pipefail

cd -- "$(dirname -- "$0")/.."

workflows=(
  .github/workflows/publish-sonatype.yml
  .github/workflows/release-doctor.yml
)
secret_fallbacks=(
  "secrets.X_TWITTER_SCRAPER_SONATYPE_USERNAME || secrets.SONATYPE_USERNAME"
  "secrets.X_TWITTER_SCRAPER_SONATYPE_PASSWORD || secrets.SONATYPE_PASSWORD"
  "secrets.X_TWITTER_SCRAPER_SONATYPE_GPG_SIGNING_KEY || secrets.GPG_SIGNING_KEY"
  "secrets.X_TWITTER_SCRAPER_SONATYPE_GPG_SIGNING_PASSWORD || secrets.GPG_SIGNING_PASSWORD"
)

for workflow in "${workflows[@]}"; do
  for fallback in "${secret_fallbacks[@]}"; do
    if ! grep -Fq "$fallback" "$workflow"; then
      printf '%s must support %s.\n' "$workflow" "$fallback"
      exit 1
    fi
  done
done

grep -Fq 'environment: maven-central' .github/workflows/publish-sonatype.yml
grep -Fq 'release_ref:' .github/workflows/publish-sonatype.yml
grep -Fq 'git describe --tags --exact-match' .github/workflows/publish-sonatype.yml
grep -Fq 'ORG_GRADLE_PROJECT_signingInMemoryKey:' .github/workflows/publish-sonatype.yml
grep -Fq 'ORG_GRADLE_PROJECT_signingInMemoryKeyPassword:' .github/workflows/publish-sonatype.yml
grep -Fq "./bin/verify-release-signature \"\$RELEASE_REF\"" \
  .github/workflows/publish-sonatype.yml
grep -Fq "./bin/verify-release-signature \"\$RELEASE_REF\"" \
  .github/workflows/release-doctor.yml

publish_line="$(
  grep -nF -- '- name: Publish signed artifacts' \
    .github/workflows/publish-sonatype.yml | cut -d: -f1
)"
verify_line="$(
  grep -nF -- '- name: Verify published signature' \
    .github/workflows/publish-sonatype.yml | cut -d: -f1
)"
if ((verify_line <= publish_line)); then
  printf 'Published signatures must be verified after publication.\n'
  exit 1
fi

printf 'Release workflows support safe Maven Central retries.\n'
