#!/usr/bin/env bash

set -euo pipefail

required_secrets=(
  SONATYPE_USERNAME
  SONATYPE_PASSWORD
  GPG_SIGNING_KEY
  GPG_SIGNING_PASSWORD
)
missing_secrets=()

for secret_name in "${required_secrets[@]}"; do
  if [[ -z "${!secret_name:-}" ]]; then
    missing_secrets+=("$secret_name")
  fi
done

if (( ${#missing_secrets[@]} > 0 )); then
  printf 'Missing release secrets:\n'
  printf '  - %s\n' "${missing_secrets[@]}"
  exit 1
fi

if [[ "${GITHUB_REF_TYPE:-}" == "tag" ]]; then
  declared_version="$(sed -n 's/.*version = "\([^"]*\)".*/\1/p' build.gradle.kts | head -1)"
  expected_tag="v${declared_version}"
  if [[ "${GITHUB_REF_NAME:-}" != "$expected_tag" ]]; then
    printf 'Release tag must be %s.\n' "$expected_tag"
    exit 1
  fi
fi

printf 'Release environment is configured.\n'
