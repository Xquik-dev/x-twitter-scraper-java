#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Xquik contributors
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail

cd -- "$(dirname -- "$0")/.."

audit_workspace="$(mktemp -d "${TMPDIR:-/tmp}/xquik-java-audit.XXXXXX")"
trap 'rm -rf -- "$audit_workspace"' EXIT

echo "==> Checking dependency licenses"
./gradlew checkLicense \
    --no-parallel \
    --no-configuration-cache \
    --no-build-cache

if [[ -n "${OSV_SCANNER_BIN:-}" ]]; then
    scanner="$OSV_SCANNER_BIN"
    if [[ ! -x "$scanner" ]]; then
        printf 'OSV_SCANNER_BIN is not executable: %s\n' "$scanner" >&2
        exit 1
    fi
else
    osv_version="2.4.0"
    platform="$(uname -s)-$(uname -m)"
    case "$platform" in
        Darwin-arm64)
            scanner_asset="osv-scanner_darwin_arm64"
            scanner_checksum="9ca3185ad63e9ab54f7cb90f46a7362be02d80e37f0123d095a54355ea202f5d"
            ;;
        Linux-x86_64)
            scanner_asset="osv-scanner_linux_amd64"
            scanner_checksum="15314940c10d26af9c6649f150b8a47c1262e8fc7e17b1d1029b0e479e8ed8a0"
            ;;
        *)
            printf 'Unsupported OSV Scanner platform: %s\n' "$platform" >&2
            exit 1
            ;;
    esac

    scanner="$audit_workspace/osv-scanner"
    scanner_url="https://github.com/google/osv-scanner/releases/download/v${osv_version}/${scanner_asset}"
    echo "==> Downloading OSV Scanner ${osv_version}"
    curl \
        --fail \
        --location \
        --proto '=https' \
        --retry 3 \
        --show-error \
        --silent \
        --tlsv1.2 \
        "$scanner_url" \
        --output "$scanner"

    if command -v sha256sum >/dev/null 2>&1; then
        actual_checksum="$(sha256sum "$scanner" | awk '{print $1}')"
    else
        actual_checksum="$(shasum -a 256 "$scanner" | awk '{print $1}')"
    fi
    if [[ "$actual_checksum" != "$scanner_checksum" ]]; then
        echo "OSV Scanner checksum verification failed." >&2
        exit 1
    fi
    chmod +x "$scanner"
fi

echo "==> Auditing locked dependencies"
"$scanner" scan source --recursive .

echo "Dependency licenses and vulnerabilities passed policy."
